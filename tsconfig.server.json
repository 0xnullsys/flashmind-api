{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "composite": true,
    "outDir": "./dist-server",
    "tsBuildInfoFile": "./dist-server/.tsbuildinfo",
    "declaration": true
  },
  "include": ["server", "api"]
}

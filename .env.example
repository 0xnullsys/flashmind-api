# FlashMind Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env with real secrets!

# === Supabase ===
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-HERE

# === Session ===
# 32+ character random string for JWT signing.
# Generate with: node -e "console.log(require("crypto").randomBytes(32).toString("hex"))"
SESSION_SECRET=change-this-to-a-random-32-character-string

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# === Cloudflare Worker Proxy ===
# URL of your deployed CF Worker that proxies HF Space.
CF_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# === Hugging Face (legacy, optional) ===
HF_SPACE_ID=your-notes2anki-space-id

# === Google OAuth (optional) ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
# Leave empty if not using Google OAuth
GOOGLE_CLIENT_SECRET=

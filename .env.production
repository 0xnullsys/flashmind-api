# Production build — loaded when `vite build --mode production`
# Used by Vercel production deployment (main branch).
# All values are SAFE to commit (no secrets, only public build config).

VITE_APP_MODE=production
VITE_APP_NAME="FlashMind"
VITE_API_BASE=/api
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true
VITE_BUILD_ID=prod-stable

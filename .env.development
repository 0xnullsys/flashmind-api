# Dev build — loaded when `vite build --mode development`
# Used by Vercel preview deployments (dev branch) and local dev server.
# All values are SAFE to commit (no secrets, only public build config).

VITE_APP_MODE=development
VITE_APP_NAME="FlashMind (Dev)"
VITE_API_BASE=/api
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false
VITE_BUILD_ID=dev-local

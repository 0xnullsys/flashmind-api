# ponytail: local secrets/scratch files (defensive layer)
# Real secrets go in .env (gitignored) or Vercel project env, never in tracked files
**/secrets.local.*
**/*.local.json
.env*.local

# ponytail: git backup/scratch dirs (created by filter-repo, manual cp)
.git.backup-*
.git.filter-backup-*
.git-rewrite*
